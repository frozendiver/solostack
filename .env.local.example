# Formspree form endpoints
# 1. Go to https://formspree.io and create a free account
# 2. Create two forms: one for the newsletter, one for tool submissions
# 3. Copy the form endpoint (looks like https://formspree.io/f/xyzabcde)
# 4. Paste the full URL below, then rename this file to .env.local

NEXT_PUBLIC_FORMSPREE_NEWSLETTER=https://formspree.io/f/YOUR_NEWSLETTER_FORM_ID
NEXT_PUBLIC_FORMSPREE_SUBMIT=https://formspree.io/f/YOUR_SUBMIT_FORM_ID
